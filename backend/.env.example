# ========= 数据库 =========
POSTGRES_DSN=postgresql://dietsearch:dev_password@localhost:5432/dietsearch
SQLITE_PATH=data/food_db.sqlite

# ========= 缓存 =========
REDIS_URL=redis://localhost:6379/0

# ========= 搜索引擎 =========
ELASTICSEARCH_URL=http://localhost:9200
ES_INDEX_NAME=restaurants

# ========= LLM（食物热量查询）=========
# 使用 DeepSeek（兼容 OpenAI SDK），也可换 Qwen 等
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-deepseek-key-here
LLM_MODEL=deepseek-chat

# ========= 高德地图 =========
GAODE_API_KEY=your-gaode-key-here

# ========= Session 安全密钥（必须配置，随机字符串 ≥ 32 位）=========
SESSION_SECRET=change-me-to-a-random-32-char-string-please

# ========= IR 配置 =========
RANKING_CONFIG_PATH=config/ranking.yaml
